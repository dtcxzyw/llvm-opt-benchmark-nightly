--- a/llvm/test/Transforms/InstCombine/fptrunc.ll
+++ b/llvm/test/Transforms/InstCombine/fptrunc.ll
@@ -240,3 +240,51 @@ define half @fptrunc_to_bfloat_bitcast_to_half(float %src) {
