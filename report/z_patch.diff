+; CHECK-NEXT:    [[EXT:%.*]] = zext nneg i32 [[SEL]] to i64
+; CHECK-NEXT:    ret i64 [[EXT]]
+;
+  %cmp = icmp slt i32 %y, %x ;
+  %sub = sub nsw i32 %x, %y ;
+  %sel = select i1 %cmp, i32 %sub, i32 0 ; (X > Y) ? X - Y : 0
